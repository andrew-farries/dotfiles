# !/bin/bash

# Git subcommand to split commits using fzf.
#  Usage: git split [-b BASE_BRANCH] [COMMIT MESSAGE]
#
#  -b : base branch to compare against (default: origin/main)
#  COMMIT MESSAGE : commit message of the commit to be split.
#
#  If the message matches only one commit, it will be split without
#  opening fzf, otherwise fzf will be invoked with <commit message> as the
#  query string.

# Set default values for the command line switches
base_ref="origin/main"

# Parse the command line arguments
while getopts "b:" opt; do
  case $opt in
    b)
      base_ref=$OPTARG
      ;;
  esac
done

# Remove the switches from the command line arguments
shift $((OPTIND-1))

# Run the fzf selection and split process
sha=$(git log --oneline $base_ref.. \
  | fzf \
    --nth='2..' \
    --height='25%' \
    --preview 'git show --color=always --name-status {1}' \
    --select-1 \
    $( [[ -n "$@" ]] && echo "--query $@" ) \
  | cut -f1 -d' ')

[ -z "$sha" ] && exit 1

git history split "$sha"
